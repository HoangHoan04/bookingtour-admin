{
  "git": {
    "deploymentEnabled": {
      "main": true,
      "develop": true
    }
  },
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://dev-api.himlamtourist.xyz",
    "VITE_APP_ENV": "development"
  },
  "build": {
    "env": {
      "VITE_API_BASE_URL": "https://dev-api.himlamtourist.xyz",
      "VITE_APP_ENV": "development"
    }
  }
}
